rules_version = '2';

// SuperRecall CAIIB — Firestore security rules
// Deploy with:  firebase deploy --only firestore:rules
//
// Threat model:
//  - A signed-in user must not grant themselves premium.
//  - A signed-in user must not fabricate XP, streak, or level values.
//  - A signed-in user must not inject unexpected fields into their profile.
//  - A signed-in user must not inflate referral counts or commission entries.
//  - All other documents are denied by default.
//
// Revenue-critical writes (subscription entitlement, referral counters,
// commission ledger) are reserved for the Firebase Admin SDK on the server,
// which bypasses these rules.

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn()   { return request.auth != null; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    // ── User-owned study data ────────────────────────────────────────────────
    // Profile reads are scoped to the owner OR a user who has already linked
    // this profile as a study partner (i.e. uid appears in their own partnerIds).
    // pairWithPartner() writes the partnership first, then reads the partner
    // profile, so the rule is satisfied by the time the read fires.
    //
    // Write validation blocks:
    //   • Attempts to inject isPremium / subscription flags
    //   • Non-numeric xp / streak / level (prevents logic bypass via type coercion)
    match /users/{uid}/profile/{doc} {
      allow read:  if isOwner(uid)
        || (signedIn()
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data)
          && uid in get(/databases/$(database)/documents/users/$(request.auth.uid)/profile/data).data.get('partnerIds', []));
      allow write: if isOwner(uid)
        && !("isPremium"    in request.resource.data)
        && !("subscription" in request.resource.data)
        && (!("xp"     in request.resource.data) || request.resource.data.xp     is number)
        && (!("streak" in request.resource.data) || request.resource.data.streak is number)
        && (!("level"  in request.resource.data) || request.resource.data.level  is number);
    }

    match /users/{uid}/cardStates/{doc}  { allow read, write: if isOwner(uid); }
    match /users/{uid}/checkpoint/{doc}  { allow read, write: if isOwner(uid); }
    match /users/{uid}/fcmTokens/{doc}   { allow read, write: if isOwner(uid); }

    // ── Study-buddy nudges ───────────────────────────────────────────────────
    // Any signed-in user may CREATE a nudge addressed to {uid}, but must stamp
    // their own uid as the sender and may only include the three expected fields.
    // Only the recipient may read or delete.
    match /users/{uid}/nudges/{nudgeId} {
      allow read, delete: if isOwner(uid);
      allow create:       if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.keys().hasOnly(['fromUid', 'sentAt', 'read']);
      allow update:       if false;
    }

    // ── Subscription entitlement (READ-ONLY to clients) ──────────────────────
    // Writing is Admin-only — a client setting isPremium:true is the exact hole
    // this closes. The server grants/revokes via the Admin SDK.
    match /users/{uid}/subscription/{doc} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Referral codes ───────────────────────────────────────────────────────
    // Any signed-in user may look up a code (pairing + referral linking need
    // this). The owner may create THEIR code with zeroed counters. Counter
    // mutations are Admin-only so referral counts can't be self-inflated.
    match /referralCodes/{code} {
      allow read:   if signedIn();
      allow create: if signedIn()
                    && request.resource.data.ownerUid == request.auth.uid
                    && request.resource.data.totalReferred == 0
                    && request.resource.data.totalCommissionEarned == 0;
      allow update, delete: if false;
    }

    // ── Commission ledger (payout data) ──────────────────────────────────────
    // Owner may read their own entries (stats panel); writes are Admin-only.
    match /commissions/{uid}/{document=**} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Daily usage counters (free-tier card-limit enforcement) ──────────────
    // Written exclusively by Firebase Admin SDK on the server (usage route) so
    // clients cannot self-reset the counter via browser DevTools or REST calls.
    // Clients may read their own document to display remaining cards.
    match /users/{uid}/usage/{doc} {
      allow read:  if isOwner(uid);
      allow write: if false;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{document=**} { allow read, write: if false; }
  }
}
