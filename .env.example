# ──────────────────────────────────────────────────────────────────
# CAIIB Platform — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────

# Gemini API key — get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Express server port (default: 3001)
PORT=3001

# Shared secret for API authentication (optional — leave blank in dev).
# When set, the Vite dev proxy injects this as X-Internal-Token so the
# browser never sees it.  In production a reverse-proxy (nginx) does the same.
INTERNAL_TOKEN=

# Allowed CORS origin in production (defaults to Vite dev server in dev)
CORS_ORIGIN=http://localhost:5173
