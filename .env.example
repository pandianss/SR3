# ──────────────────────────────────────────────────────────────────
# CAIIB Platform — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ──────────────────────────────────────────────────────────────────

# ── Gemini API (server-side only) ────────────────────────────────
# Obtain from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Express server port (default: 3001)
PORT=3001

# ── Internal request guard ────────────────────────────────────────
# A strong random secret shared between the reverse proxy (nginx) and this
# server. The Vite dev proxy injects it automatically; nginx must do the
# same in production so the browser never sees it.
# Generate: openssl rand -hex 32
# Leave blank in local dev to skip the check.
INTERNAL_TOKEN=

# Allowed CORS origin in production (defaults to Vite dev server in dev)
CORS_ORIGIN=http://localhost:5173

# Backend API URL for production APK builds (Capacitor WebView can't use Vite proxy).
# Leave blank in dev — the Vite proxy handles /api/* → localhost:3001 automatically.
# Example: https://api.superrecall.in
VITE_API_BASE_URL=

# ── Firebase Admin SDK (server-side) ─────────────────────────────
# Enables server-side Firestore writes (subscription grants, commissions).
# Generate from: Firebase Console → Project Settings → Service Accounts
#                → Generate new private key
# Paste the entire JSON as a single line (minify it first).
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── Force-refresh guard ───────────────────────────────────────────
# Protects the ?refresh=true endpoint that triggers a full RBI scrape.
# Any strong random string. Leave blank in dev to allow free re-scrape.
# Generate: openssl rand -hex 32
REFRESH_SECRET=

# ── Google Pub/Sub billing webhook OIDC verification ──────────────
# Required in production to prevent forged RTDN webhook events.
# PUBSUB_SA_EMAIL: service account email shown in Play Console → Pub/Sub subscription.
#   Looks like: service-NNNNN@gcp-sa-pubsub.iam.gserviceaccount.com
# PUBSUB_AUDIENCE_URL: the full public URL of the webhook endpoint.
#   Must exactly match what was configured in the Pub/Sub push subscription.
#   Example: https://api.superrecall.in/api/billing/webhook
# Leave both blank in dev to skip OIDC verification.
PUBSUB_SA_EMAIL=
PUBSUB_AUDIENCE_URL=

# ── Circulars file-cache directory ────────────────────────────────
# Directory where circulars.json is persisted across restarts.
# Defaults to /tmp (writable on Railway, Render, Docker).
# Set to a mounted persistent-volume path if you want cache to
# survive container restarts on platforms that support it.
# Example: /data/cache
CACHE_DIR=/tmp

# ── Firebase (client-side) ────────────────────────────────────────
# 1. Go to https://console.firebase.google.com
# 2. Enable Authentication > Sign-in method > Google
# 3. Enable Firestore Database (production mode + deploy firestore.rules)
# 4. Project Settings > Your apps > Add web app > copy firebaseConfig values
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:your_sender_id:web:your_app_id
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── App Check (web) ───────────────────────────────────────────────
# Protects Firebase APIs from unauthenticated clients and bot abuse.
# reCAPTCHA v3 site key from: https://www.google.com/recaptcha/admin
# Leave blank to skip App Check on web (Android uses Play Integrity separately).
VITE_RECAPTCHA_SITE_KEY=

# Debug token for App Check in development.
# Generate from: Firebase Console → App Check → Apps → Manage debug tokens
VITE_APP_CHECK_DEBUG_TOKEN=
